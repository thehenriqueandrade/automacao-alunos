        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "nome", "fieldValue": "={{ $('Normalizar Campos').item.json.produto }}" }
          ]
        }
      },
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase — jornada_alunos"
        }
      }
    },
    {
      "id": "w1-node-009",
      "name": "Produto Criado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2220, 400],
      "parameters": {
