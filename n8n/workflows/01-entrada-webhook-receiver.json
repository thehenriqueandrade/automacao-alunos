{
  "name": "01 — Entrada: Webhook Receiver (Pagtrust)",
  "active": false,
  "nodes": [
    {
      "id": "w1-node-001",
      "name": "Pagtrust — Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "pagtrust-entrada-001",
      "parameters": {
        "httpMethod": "POST",
        "path": "pagtrust",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "w1-node-002",
      "name": "Normalizar Campos",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
            {
              "name": "nome",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.buyer.name }}"
            },
            {
              "name": "whatsapp",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.buyer.checkout_phone.toString().replace(/\\D/g, '') }}"
            },
            {
              "name": "email",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.buyer.email }}"
            },
            {
              "name": "order_id",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.purchase.transaction }}"
            },
            {
              "name": "valor",
              "type": "numberValue",
              "numberValue": "={{ $json.body.data.purchase.full_price.value }}"
            },
            {
              "name": "status",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.purchase.status }}"
            },
            {
              "name": "event",
              "type": "stringValue",
              "stringValue": "={{ $json.body.event }}"
            },
            {
              "name": "produto",
              "type": "stringValue",
              "stringValue": "={{ $json.body.data.product.name }}"
            },
            {
              "name": "dados_raw",
              "type": "objectValue",
              "objectValue": "={{ $json.body }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "w1-node-003",
      "name": "Supabase — Upsert Aluno",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/alunos?on_conflict=whatsapp",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "resolution=merge-duplicates,return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ nome: $json.nome, whatsapp: $json.whatsapp, email: $json.email }) }}",
        "options": {
          "failOnStatusCode": false
        }
      }
    },
    {
      "id": "w1-node-004",
      "name": "Supabase — Insert Transação",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/transacoes?on_conflict=order_id",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "resolution=merge-duplicates" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ order_id: $('Normalizar Campos').item.json.order_id, aluno_id: $json[0].id, valor: $('Normalizar Campos').item.json.valor, status: $('Normalizar Campos').item.json.status, dados_raw: $('Normalizar Campos').item.json.dados_raw }) }}",
        "options": {
          "failOnStatusCode": false
        }
      }
    },
    {
      "id": "w1-note-001",
      "name": "Nota — Variáveis",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [240, 80],
      "parameters": {
        "content": "## Fluxo 01 — Webhook Receiver\n\n**Variáveis de ambiente necessárias (n8n Settings → Variables):**\n- `SUPABASE_URL` — ex: https://xxxx.supabase.co\n- `SUPABASE_SERVICE_ROLE_KEY` — Service Role Key do Supabase\n\n**Nenhuma credential necessária** — autenticação via variáveis de ambiente.\n\n**URL do webhook gerado:**\nhttps://[seu-n8n]/webhook/pagtrust",
        "height": 180,
        "width": 660
      }
    }
  ],
  "connections": {
    "Pagtrust — Webhook": {
      "main": [
        [{ "node": "Normalizar Campos", "type": "main", "index": 0 }]
      ]
    },
    "Normalizar Campos": {
      "main": [
        [{ "node": "Supabase — Upsert Aluno", "type": "main", "index": 0 }]
      ]
    },
    "Supabase — Upsert Aluno": {
      "main": [
        [{ "node": "Supabase — Insert Transação", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
